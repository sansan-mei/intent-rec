# Intent Demo：Hono + LangChain(ChatOpenAI 兼容模式) + 千问

# 阿里云 DashScope — OpenAI 兼容模式（千问）
# https://help.aliyun.com/zh/model-studio/developer-reference/use-qwen-by-calling-api
DASHSCOPE_API_KEY=

# 可选：未设置 DASHSCOPE_API_KEY 时回退读此变量（兼容通用 OpenAI 客户端命名）
OPENAI_API_KEY=

# 兼容模式 Base URL（默认即为 DashScope）
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 千问主链路：属性抽取等（qwen-turbo-latest / qwen-flash / qwen-plus 等，按百炼控制台可用名为准）
MODEL_NAME=qwen-turbo-latest

# 单次请求超时（ms）
LLM_TIMEOUT_MS=15000

# 四类意图分类（AI助手.yml）：默认开启；设为 false 则固定找货、不调用意图模型
INTENT_CLASSIFICATION_ENABLED=true

# 热搜词典：命中则跳过意图 LLM，仍会调用属性抽取 LLM
SEARCH_DICTIONARY_ENABLED=true

# 可选：追加词典 JSON 路径，格式：[{"tag_id":123,"patterns":["词A","词B"]}, ...]
# SEARCH_DICTIONARY_EXTRA_PATH=./data/search_dictionary.extra.json
